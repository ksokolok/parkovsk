@ВПроекте
метод ПолучитьКоличествоСвободныхМест(): Число
    знч ДатаОстатков = ДатаВремя.Сейчас()
    знч Запрос = Запрос{
        ВЫБРАТЬ
            ОстаткиСвободныхМестОстатки.КоличествоСвободныхМестОстаток КАК КоличествоОстаток
        ИЗ
            ОстаткиСвободныхМест.Остатки(%ДатаОстатков) КАК ОстаткиСвободныхМестОстатки
        
    }
    
    знч РезультатЗапроса = Запрос.Выполнить()
    
    возврат РезультатЗапроса.ЕдинственныйИлиНеопределено().КоличествоОстаток
;